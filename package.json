{
  "name": "student-productivity-hub",
  "version": "0.1.0",
  "description": "A mobile-first study operating system with authentication, planning, and quiz workflows.",
  "private": true,
  "author": "Arti Sri Ravikumar",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/aartisr/student-productivity-hub.git"
  },
  "bugs": {
    "url": "https://github.com/aartisr/student-productivity-hub/issues"
  },
  "homepage": "https://github.com/aartisr/student-productivity-hub#readme",
  "keywords": [
    "student-productivity",
    "nextjs",
    "education",
    "quiz"
  ],
  "scripts": {
    "dev": "node scripts/clear-next-dev-lock.mjs && next dev",
    "dev:stop": "node scripts/restart-next-dev.mjs",
    "dev:restart": "node scripts/restart-next-dev.mjs && node scripts/clear-next-dev-lock.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "next": "16.1.7",
    "next-auth": "^4.24.13",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
